# ========================================
# AI 大模型应用开发 - 环境变量配置模板
# ========================================
#
# 使用说明：
# 1. 复制此文件为 .env（不要提交到Git）
# 2. 填入你的真实API密钥
# 3. 代码会自动从 .env 文件读取配置
#
# ⚠️ 安全提示：
# - 永远不要将 .env 文件提交到版本控制系统
# - 不要在任何地方分享你的 API Key
# ========================================

# ==================== LLM API 配置（OpenAI 兼容标准）====================
# API 密钥（必填）
OPENAI_API_KEY=your_api_key_here

# API 基础URL（OpenAI兼容接口）
# - DeepSeek: https://api.deepseek.com/v1
# - OpenAI: https://api.openai.com/v1
OPENAI_BASE_URL=https://api.deepseek.com/v1

# 默认使用的模型名称
OPENAI_MODEL=deepseek-v4-flash

# ==================== LLM 参数配置 ====================
TEMPERATURE=0.7
MAX_TOKENS=1024
REQUEST_TIMEOUT=30
MAX_RETRIES=3

# ==================== 向量模型配置（RAG阶段使用）====================
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
EMBEDDING_DEVICE=cpu

# ==================== HuggingFace 配置 ====================
HF_ENDPOINT=https://hf-mirror.com

# ==================== 其他配置 ====================
DEBUG=false
LOG_LEVEL=INFO
